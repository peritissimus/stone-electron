    "@tiptap/extension-link": "^2.26.4",
    "@tiptap/extension-placeholder": "^2.27.1",
    "@tiptap/extension-table": "^2.27.1",
    "@tiptap/extension-table-cell": "^2.27.1",
    "@tiptap/extension-table-header": "^2.27.1",
    "@tiptap/extension-table-row": "^2.27.1",
    "@tiptap/extension-task-item": "^2.27.1",
    "@tiptap/extension-task-list": "^2.27.1",
    "@tiptap/pm": "^2.27.1",
    "@tiptap/react": "^2.26.4",
    "@tiptap/starter-kit": "^2.26.4",
    "@tiptap/suggestion": "^2.27.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^20.10.6",
    "@types/react": "^18.2.46",
    "@types/react-dom": "^18.2.18",
    "@types/turndown": "^5.0.6",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^1.1.0",
    "@vitest/ui": "^1.1.0",
    "@welldone-software/why-did-you-render": "^10.0.1",
    "@xenova/transformers": "^2.6.5",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "cmdk": "^1.1.1",
    "concurrently": "^8.2.2",
    "conventional-changelog-conventionalcommits": "^9.1.0",
    "cypress": "^15.7.1",
    "date-fns": "^2.30.0",
    "drizzle-kit": "^0.31.6",
    "electron": "33.4.11",
    "electron-builder": "^24.6.4",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "highlight.js": "^11.11.1",
    "jsdom": "^27.1.0",
    "lowlight": "^2.9.0",
    "lucide-react": "^0.548.0",
    "markdown-it": "^13.0.2",
    "mermaid": "^11.12.1",
    "phosphor-react": "^1.4.1",
    "prettier": "^3.1.1",
    "prismjs": "^1.29.0",
    "react": "^18.2.0",
    "react-devtools": "^7.0.1",
    "react-dom": "^18.2.0",
    "react-query": "^3.39.3",
    "rollup-plugin-visualizer": "^6.0.5",
    "semantic-release": "^24.2.9",
    "shadcn-ui": "^0.8.0",
    "start-server-and-test": "^2.1.3",
    "tailwind-merge": "^2.2.1",
    "tailwindcss": "^4.1.16",
    "tippy.js": "^6.3.7",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vectra": "^0.3.0",
    "vite": "^5.0.8",
    "vitest": "^1.1.0",
    "wait-on": "^9.0.1",
    "zustand": "^4.4.7"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
