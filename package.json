{
  "name": "stone",
  "version": "0.2.14",
  "description": "Production-ready note-taking desktop application",
  "main": "./dist/main/index.cjs",
  "type": "module",
  "author": "peritissimus",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/peritissimus/stone.git"
  },
  "homepage": "https://github.com/peritissimus/stone#readme",
  "bugs": {
    "url": "https://github.com/peritissimus/stone/issues"
  },
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "build:main": "vite build --config vite.main.config.ts",
    "build:preload": "vite build --config vite.preload.config.ts",
    "build:renderer": "vite build --config vite.renderer.config.ts",
    "start": "electron .",
    "preview": "vite preview",
    "package": "electron-builder",
    "package:dir": "electron-builder --dir",
    "package:all": "electron-builder -mwl",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "start-server-and-test dev http://localhost:5173 cy:run",
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,md}\"",
    "typecheck": "tsc --noEmit",
    "sonar": "vitest run --coverage && sonar-scanner",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push",
    "fs:check": "tsx -r tsconfig-paths/register scripts/fs-sync-check.ts",
    "fs:scan": "tsx scripts/fs-scan-only.ts",
    "server": "tsx src/main/api/standalone.ts",
    "server:dev": "tsx watch src/main/api/standalone.ts",
    "release": "./scripts/release.sh patch",
    "release:minor": "./scripts/release.sh minor",
    "release:major": "./scripts/release.sh major",
    "postinstall": "electron-rebuild --ignore better-sqlite3",
    "react-devtools": "react-devtools"
  },
  "dependencies": {
    "@fontsource/barlow": "^5.2.8",
    "@fontsource/barlow-condensed": "^5.2.8",
    "@fontsource/barlow-semi-condensed": "^5.2.7",
    "@fontsource/fira-code": "^5.2.7",
    "@fontsource/inter": "^5.2.8",
    "@hono/node-server": "^1.19.7",
    "@libsql/client": "^0.15.15",
    "@radix-ui/react-context-menu": "^2.2.16",
    "awilix": "^12.0.5",
    "chokidar": "^4.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.44.7",
    "electron-log": "^5.4.3",
    "electron-store": "^8.0.0",
    "express": "^5.2.1",
    "font-list": "^2.0.1",
    "gray-matter": "^4.0.3",
    "hono": "^4.11.3",
    "marked": "^16.4.1",
    "nanoid": "3.3.7",
    "react-force-graph": "^1.48.1",
    "react-force-graph-2d": "^1.29.0",
    "turndown": "^7.2.2",
    "turndown-plugin-gfm": "^1.0.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.1",
    "@fontsource/patrick-hand": "^5.2.8",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.2",
    "@tailwindcss/postcss": "^4.1.16",
