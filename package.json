{
  "name": "stone",
  "version": "0.6.6",
  "description": "Production-ready note-taking desktop application",
  "main": "./dist/main/index.cjs",
  "type": "module",
  "packageManager": "pnpm@10.27.0",
  "author": "peritissimus",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/peritissimus/stone-electron.git"
  },
  "homepage": "https://github.com/peritissimus/stone-electron#readme",
  "bugs": {
    "url": "https://github.com/peritissimus/stone-electron/issues"
  },
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "npm run build:main && npm run build:worker && npm run build:preload && npm run build:renderer",
    "build:worker": "vite build --config vite.worker.config.ts",
    "build:main": "vite build --config vite.main.config.ts",
    "build:preload": "vite build --config vite.preload.config.ts",
    "build:renderer": "vite build --config vite.renderer.config.ts",
    "start": "electron .",
    "preview": "vite preview",
    "package": "electron-builder",
    "package:dir": "electron-builder --dir",
    "package:all": "electron-builder -mwl",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage run",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:ui": "npm run build && playwright test --ui",
    "test:e2e:headed": "npm run build && playwright test --headed",
    "test:e2e:nobuild": "playwright test",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,md}\"",
    "typecheck": "tsc --noEmit",
    "sonar": "vitest run --coverage && sonar-scanner",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push",
    "fs:check": "tsx -r tsconfig-paths/register scripts/fs-sync-check.ts",
    "fs:scan": "tsx scripts/fs-scan-only.ts",
    "server": "tsx src/main/api/standalone.ts",
    "server:dev": "tsx watch src/main/api/standalone.ts",
    "release": "./scripts/release.sh patch",
    "release:minor": "./scripts/release.sh minor",
    "release:major": "./scripts/release.sh major",
    "postinstall": "electron-rebuild",
    "react-devtools": "react-devtools",
    "build:whisper": "./scripts/build-whisper.sh"
  },
  "dependencies": {
    "@ai-sdk/azure": "^3.0.74",
    "@ai-sdk/google": "^3.0.79",
    "@ai-sdk/groq": "^3.0.41",
    "@ai-sdk/openai": "^3.0.65",
    "@fontsource/barlow": "^5.2.8",
    "@fontsource/barlow-condensed": "^5.2.8",
    "@fontsource/barlow-semi-condensed": "^5.2.7",
    "@fontsource/fira-code": "^5.2.7",
    "@fontsource/inter": "^5.2.8",
    "@libsql/client": "^0.15.15",
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@xenova/transformers": "^2.6.5",
    "ai": "^6.0.191",
    "chokidar": "^4.0.3",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.2",
    "electron-log": "^5.4.3",
    "font-list": "^2.0.1",
    "glob": "^13.0.0",
    "html-to-image": "^1.11.11",
    "nanoid": "3.3.8",
    "onnxruntime-node": "1.14.0",
    "react-force-graph-2d": "^1.29.0",
    "react-router-dom": "^7.15.0",
    "simple-git": "^3.36.0",
    "sonner": "^2.0.7",
    "turndown": "^7.2.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.1",
    "@fontsource/patrick-hand": "^5.2.8",
    "@playwright/test": "^1.59.1",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/postcss": "^4.1.16",
    "@tiptap/core": "^2.26.4",
    "@tiptap/extension-code-block-lowlight": "^2.27.1",
    "@tiptap/extension-highlight": "^2.26.4",
    "@tiptap/extension-link": "^2.26.4",
    "@tiptap/extension-placeholder": "^2.27.1",
    "@tiptap/extension-table": "^2.27.1",
    "@tiptap/extension-table-cell": "^2.27.1",
    "@tiptap/extension-table-header": "^2.27.1",
    "@tiptap/extension-table-row": "^2.27.1",
    "@tiptap/extension-task-list": "^2.27.1",
    "@tiptap/pm": "^2.27.1",
    "@tiptap/react": "^2.26.4",
    "@tiptap/starter-kit": "^2.26.4",
    "@tiptap/suggestion": "^2.27.1",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^20.10.6",
    "@types/react": "^18.2.46",
    "@types/react-dom": "^18.2.18",
    "@types/turndown": "^5.0.6",
    "@typescript-eslint/eslint-plugin": "^8.52.0",
    "@typescript-eslint/parser": "^8.52.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^1.1.0",
    "@vitest/ui": "^1.1.0",
    "@welldone-software/why-did-you-render": "^10.0.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "cmdk": "^1.1.1",
    "concurrently": "^8.2.2",
    "date-fns": "^2.30.0",
    "drizzle-kit": "^0.31.6",
    "electron": "33.4.11",
    "electron-builder": "^24.6.4",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "highlight.js": "^11.11.1",
    "jsdom": "^27.1.0",
    "lowlight": "^2.9.0",
    "lucide-react": "^0.548.0",
    "markdown-it": "^13.0.2",
    "mermaid": "^11.12.1",
    "prettier": "^3.1.1",
    "react": "^18.2.0",
    "react-devtools": "^7.0.1",
    "react-dom": "^18.2.0",
    "rollup-plugin-visualizer": "^6.0.5",
    "tailwind-merge": "^2.2.1",
    "tailwindcss": "^4.1.16",
    "tippy.js": "^6.3.7",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "vitest": "^1.1.0",
    "wait-on": "^9.0.1",
    "zustand": "^4.4.7"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "workspaces": [
    "."
  ],
  "pnpm": {
    "overrides": {
      "protobufjs": ">=7.5.8",
      "ws": ">=8.20.1",
      "lodash-es": ">=4.18.0",
      "preact": ">=10.28.2",
      "glob>minimatch": ">=10.2.3",
      "minimatch>@isaacs/brace-expansion": ">=5.0.1"
    }
  }
}
