{
  "compilerOptions": {
    "target": "ES2021",
    "useDefineForClassFields": true,
    "lib": ["ES2021", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@main/*": ["src/main/*"],
      "@domain": ["src/main/domain/index.ts"],
      "@domain/*": ["src/main/domain/*"],
      "@application": ["src/main/application/index.ts"],
      "@application/*": ["src/main/application/*"],
      "@adapters": ["src/main/adapters/index.ts"],
      "@adapters/*": ["src/main/adapters/*"],
      "@infrastructure": ["src/main/infrastructure/index.ts"],
      "@infrastructure/*": ["src/main/infrastructure/*"],
      "@renderer/*": ["src/renderer/*"],
      "@shared/*": ["src/shared/*"]
    },
    "types": ["node", "vitest/globals", "vite/client"]
  },
  "include": ["src", "tests"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
